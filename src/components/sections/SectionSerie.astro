---
import Layout from "@layouts/Layout.astro";
import Smoke from "@components/effects/SmokeEffect.astro";
---

<Layout>
  <section id="portal-section" aria-label="Portal hacia la serie">
    <div class="portal-background"></div>
    <Smoke />

    <div id="fire-ring-wrapper" aria-hidden="true">
      <div id="fire-ring"></div>
    </div>

    <span class="runes">ᚱᚨᛁᛞᛟ</span>
    <span class="runes">ᚨᚾᛊᚢᛉ</span>
    <span class="runes">ᚲᛖᚾᚨᛉ</span>

    <div class="info">
      <p>
        Cruza la senda de piedra donde los antiguos caminos conducen hacia los
        salones de los dioses y los cuervos de Odín custodian la memoria del
        norte.
        <br /><br />
        Allí, bajo las ramas eternas de Yggdrasil, las voces olvidadas aún susurran
        entre la niebla y anuncian el destino de <span class="title"
          >Valheim: Larga vida a La Reina.</span
        >
      </p>
    </div>

    <canvas id="portal-canvas"></canvas>

    <div id="portal-hint">
      <span class="hint-rune">ᛈ</span>
      <span class="hint-text">Pasa el cursor por el portal</span>
      <span class="hint-rune" style="transform: scaleX(-1)">ᛈ</span>
    </div>
  </section>
</Layout>

<style>
  /* ─── Layout base ──────────────────────────────────────────────────────── */

  #portal-section {
    position: relative;
    width: 100%;
    height: 110vh;
    overflow: hidden;
    cursor: default;
    background-color: #000000;
  }

  /* Capas apiladas (de fondo a frente):
     0  .portal-background   imagen estática
     1  #smoke                humo (definido en SmokeEffect.astro)
     2  #portal-canvas        portal WebGL (transparente fuera de la máscara)
     5  .info / .runes / #portal-hint
  */

  .portal-background {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: url("/images/backgrounds/portal_background.png");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    pointer-events: none;
  }

  #portal-canvas {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: block;
    width: 100%;
    height: 100%;
    background-color: transparent;
  }

  /* ─── Texto narrativo ──────────────────────────────────────────────────── */

  .info {
    position: absolute;
    top: 50%;
    left: 8rem;
    transform: translateY(-50%);
    max-width: 45vw;
    max-height: 550px;
    text-wrap: pretty;
    font-size: clamp(1rem, 2.7273vw + 0.4545rem, 2.8rem);
    line-height: 1.2;
    display: flex;
    flex-direction: column;
    z-index: 5;
  }

  .info > p {
    color: var(--color-gold-light);
    text-shadow:
      0 0 2px #000,
      0 0 4px #000,
      0 1px 16px #080300,
      0 1px 24px #000;
  }

  .title {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: clamp(1.2rem, 3.2727vw + 0.5455rem, 3.5rem);
    text-wrap: nowrap;
    font-weight: bold;
    color: #bf6515;
    opacity: 0.85;
    text-shadow:
      0 0 2px #000,
      0 2px 4px rgba(0, 0, 0, 0.8),
      0 0 8px rgba(212, 175, 55, 0.6),
      2px 2px 8px rgba(101, 82, 40, 0.5),
      -1px -1px 2px rgba(0, 0, 0, 0.4);
    font-family: "Cinzel", serif;
    filter: contrast(1.15) brightness(1.1) saturate(1.2) sepia(0.5);
  }

  /* ─── Runas decorativas ───────────────────────────────────────────────── */

  .runes {
    display: block;
    position: absolute;
    z-index: 5;
    font-family: "Runes", "Cinzel", "Palatino Linotype", serif;
    letter-spacing: 1rem;
    font-weight: bold;
    color: #573c2a;
    text-shadow: 0px 0px 2px #3d3020;
    filter:
      drop-shadow(0 0 8px #00000088) drop-shadow(0 0 16px #0000004d)
        drop-shadow(0 0 24px #8b5a0044),
      drop-shadow(0 0 32px #573c2a);
    opacity: 0.5;
  }

  .runes:nth-child(4) {
    top: 4.5rem;
    left: 0;
    font-size: clamp(3rem, 12.7273vw + 0.4545rem, 11rem);
  }

  .runes:nth-child(5) {
    top: 50%;
    left: 1rem;
    transform: translateY(-50%);
    font-size: clamp(2rem, 10.9091vw + -0.1818rem, 8rem);
  }

  .runes:nth-child(6) {
    bottom: 4.5rem;
    left: 0;
    font-size: clamp(3rem, 12.7273vw + 0.4545rem, 11rem);
  }

  /* ─── Hint de interacción ─────────────────────────────────────────────── */

  #portal-hint {
    position: absolute;
    z-index: 5;
    bottom: 5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    color: rgba(255, 200, 100, 0.75);
    font-family: "Cinzel", "Palatino Linotype", serif;
    font-size: clamp(0.75rem, 1.5vw, 1rem);
    letter-spacing: 0.15em;
    text-shadow: 0 0 12px rgba(255, 120, 0, 0.5);
    pointer-events: none;
    transition: opacity 0.6s ease;
    background-color: #000000aa;
    animation: textGlow 3s ease-in-out infinite alternate;
  }

  #portal-hint.hidden {
    opacity: 0;
  }

  .hint-rune {
    font-size: 1.2em;
    animation: runeFlicker 2.5s ease-in-out infinite alternate;
  }

  .hint-rune:last-child {
    animation-delay: 1.25s;
  }

  /* ─── Animaciones ─────────────────────────────────────────────────────── */

  @keyframes textGlow {
    0% {
      box-shadow: 0 0 6px rgba(136, 54, 0, 0.2);
    }
    50% {
      box-shadow: 0 0 18px rgba(139, 88, 0, 0.5);
    }
    100% {
      box-shadow: 0 0 6px rgba(116, 47, 1, 0.2);
    }
  }

  @keyframes runeFlicker {
    0% {
      opacity: 0.4;
      text-shadow: 0 0 6px rgba(255, 100, 0, 0.3);
    }
    100% {
      opacity: 1;
      text-shadow: 0 0 18px rgba(255, 160, 0, 0.9);
    }
  }

  #portal-section.portal-zoom {
    animation: portalZoom 2s ease-in forwards;
    transform-origin: 75% 55%;
  }

  @keyframes portalZoom {
    0% {
      transform: scale(1);
      opacity: 1;
    }
    100% {
      transform: scale(15);
    }
  }
</style>

<script>
  import * as THREE from "three";
  import { navigate } from "astro:transitions/client";

  // ─── Configuración ───────────────────────────────────────────────────────

  const TEXTURES = {
    base: "/images/portal/portal.png",
    active: "/images/portal/portal_active.png",
    mask: "/images/portal/portal_mask.png",
  } as const;

  const NAVIGATION_TARGET = "/serie";
  const ZOOM_DELAY_MS = 1500;
  const HOVER_LERP = 0.04;

  const CURSOR_OVER = 'url("/cursor/pointer_fixed.cur") 16 2, pointer';
  const CURSOR_OUT = 'url("/cursor/cursor_fixed.cur") 0 0, auto';

  // ─── Shaders ─────────────────────────────────────────────────────────────

  const vertexShader = /* glsl */ `
    varying vec2 vUv;
    void main() {
      vUv = uv;
      gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    }
  `;

  const fragmentShader = /* glsl */ `
    uniform sampler2D uTexBase;
    uniform sampler2D uTexActive;
    uniform sampler2D uMask;
    uniform float     uTime;
    uniform float     uHover;

    varying vec2 vUv;

    float hash(vec2 p) {
      return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
    }

    float noise(vec2 p) {
      vec2 i = floor(p);
      vec2 f = fract(p);
      f = f * f * (3.0 - 2.0 * f);
      return mix(
        mix(hash(i),                  hash(i + vec2(1.0, 0.0)), f.x),
        mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), f.x),
        f.y
      );
    }

    float fbm(vec2 p) {
      float value = 0.0;
      float amp   = 0.5;
      for (int i = 0; i < 5; i++) {
        value += amp * noise(p);
        p     *= 2.1;
        amp   *= 0.5;
      }
      return value;
    }

    void main() {
      float mask      = texture2D(uMask,      vUv).r;
      vec4  base      = texture2D(uTexBase,   vUv);
      vec4  texActive = texture2D(uTexActive, vUv);

      float noiseVal  = fbm(vUv * 4.0 + uTime * 0.3);
      float threshold = uHover + noiseVal * 0.15 - 0.075;
      float blend     = smoothstep(0.0, 1.0, threshold) * mask;

      gl_FragColor = mix(base, texActive, blend);
    }
  `;

  // ─── Estado de módulo (cleanup entre navegaciones SPA) ──────────────────

  let animationId: number | null = null;
  let renderer: THREE.WebGLRenderer | null = null;
  let resizeObserver: ResizeObserver | null = null;
  let cleanupListeners: (() => void) | null = null;

  function dispose() {
    if (animationId !== null) {
      cancelAnimationFrame(animationId);
      animationId = null;
    }
    resizeObserver?.disconnect();
    resizeObserver = null;
    cleanupListeners?.();
    cleanupListeners = null;
    renderer?.dispose();
    renderer = null;
  }

  // ─── Helpers ─────────────────────────────────────────────────────────────

  function createMaskSampler(image: HTMLImageElement) {
    const c = document.createElement("canvas");
    const ctx = c.getContext("2d", { willReadFrequently: true })!;
    c.width = image.naturalWidth || 256;
    c.height = image.naturalHeight || 144;
    ctx.drawImage(image, 0, 0, c.width, c.height);

    return (uvX: number, uvY: number): boolean => {
      const x = Math.floor(Math.max(0, Math.min(0.999, uvX)) * c.width);
      const y = Math.floor(Math.max(0, Math.min(0.999, uvY)) * c.height);
      return ctx.getImageData(x, y, 1, 1).data[0] > 128;
    };
  }

  function uvFromEvent(canvas: HTMLCanvasElement, e: MouseEvent) {
    const rect = canvas.getBoundingClientRect();
    return {
      x: (e.clientX - rect.left) / rect.width,
      y: (e.clientY - rect.top) / rect.height,
    };
  }

  // ─── Inicialización ──────────────────────────────────────────────────────

  async function initPortal() {
    dispose();

    const canvas = document.getElementById(
      "portal-canvas",
    ) as HTMLCanvasElement | null;
    const section = document.getElementById(
      "portal-section",
    ) as HTMLElement | null;
    const hint = document.getElementById("portal-hint") as HTMLElement | null;

    if (!canvas || !section || !hint) return;

    section.classList.remove("portal-zoom");

    // ─── Renderer transparente (deja ver el fondo + smoke) ────────────────

    renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: true,
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setClearColor(0x000000, 0);

    const scene = new THREE.Scene();
    const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);

    // ─── Texturas ─────────────────────────────────────────────────────────

    const loader = new THREE.TextureLoader();
    const [texBase, texActive, texMask] = await Promise.all([
      loader.loadAsync(TEXTURES.base),
      loader.loadAsync(TEXTURES.active),
      loader.loadAsync(TEXTURES.mask),
    ]);

    const uniforms = {
      uTexBase: { value: texBase },
      uTexActive: { value: texActive },
      uMask: { value: texMask },
      uTime: { value: 0.0 },
      uHover: { value: 0.0 },
    };

    const material = new THREE.ShaderMaterial({
      uniforms,
      vertexShader,
      fragmentShader,
      transparent: true,
    });

    scene.add(new THREE.Mesh(new THREE.PlaneGeometry(2, 2), material));

    const sampleMask = createMaskSampler(texMask.image as HTMLImageElement);

    // ─── Resize ───────────────────────────────────────────────────────────

    const resize = () => {
      renderer!.setSize(section.clientWidth, section.clientHeight, false);
    };
    resize();
    resizeObserver = new ResizeObserver(resize);
    resizeObserver.observe(section);

    // ─── Hover (lerp suave hacia hoverTarget) ─────────────────────────────

    let hoverTarget = 0.0;

    const onMouseMove = (e: MouseEvent) => {
      const { x, y } = uvFromEvent(canvas, e);
      if (x < 0 || x > 1 || y < 0 || y > 1) return;

      const overPortal = sampleMask(x, y);
      hoverTarget = overPortal ? 1.0 : 0.0;
      canvas.style.cursor = overPortal ? CURSOR_OVER : CURSOR_OUT;
      hint.classList.toggle("hidden", overPortal);
    };

    const onMouseLeave = () => {
      hoverTarget = 0.0;
      canvas.style.cursor = "default";
      hint.classList.remove("hidden");
    };

    const onClick = (e: MouseEvent) => {
      const { x, y } = uvFromEvent(canvas, e);
      if (!sampleMask(x, y)) return;

      section.classList.add("portal-zoom");
      setTimeout(() => navigate(NAVIGATION_TARGET), ZOOM_DELAY_MS);
    };

    section.addEventListener("mousemove", onMouseMove);
    section.addEventListener("mouseleave", onMouseLeave);
    canvas.addEventListener("click", onClick);

    cleanupListeners = () => {
      section.removeEventListener("mousemove", onMouseMove);
      section.removeEventListener("mouseleave", onMouseLeave);
      canvas.removeEventListener("click", onClick);
    };

    // ─── Loop ─────────────────────────────────────────────────────────────

    const clock = new THREE.Timer();

    const animate = () => {
      animationId = requestAnimationFrame(animate);
      uniforms.uTime.value = clock.getElapsed();
      uniforms.uHover.value = THREE.MathUtils.lerp(
        uniforms.uHover.value,
        hoverTarget,
        HOVER_LERP,
      );
      renderer!.render(scene, camera);
    };
    animate();
  }

  initPortal();
  document.addEventListener("astro:page-load", initPortal);
</script>
