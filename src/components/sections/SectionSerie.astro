---
import Layout from "@layouts/Layout.astro";
import Smoke from "@components/effects/SmokeEffect.astro";
---

<Layout>
  <section id="portal-section" aria-label="Portal hacia la serie">
    <Smoke />
    <span class="runes">ᚱᚨᛁᛞᛟ</span>
    <span class="runes">ᚨᚾᛊᚢᛉ</span>
    <span class="runes">ᚲᛖᚾᚨᛉ</span>
    <div class="info">
      <p>
        Cruza la senda de piedra donde los antiguos caminos conducen hacia los
        salones de los dioses y los cuervos de Odín custodian la memoria del
        norte.
        <br /><br />
        Allí, bajo las ramas eternas de Yggdrasil, las voces olvidadas aún susurran
        entre la niebla y anuncian el destino de <span class="title"
          >Valheim: Larga vida a La Reina.</span
        >
      </p>
    </div>
    <canvas id="portal-canvas"></canvas>
    <div id="portal-hint">
      <span class="hint-rune">ᛈ</span>
      <span class="hint-text">Pasa el cursor por el portal</span>
      <span class="hint-rune" style="transform: scaleX(-1)">ᛈ</span>
    </div>
  </section>
</Layout>

<style>
  .info {
    position: absolute;
    top: 50%;
    left: 8rem;
    transform: translateY(-50%);
    max-width: 45vw;
    max-height: 550px;
    text-wrap: pretty;
    font-size: clamp(1rem, 2.7273vw + 0.4545rem, 2.8rem);
    line-height: 1.2;
    display: flex;
    flex-direction: column;
    z-index: 10;
  }

  .info > p {
    color: var(--color-gold-light);
    text-shadow:
      0 0 2px #000,
      0 0 4px #000,
      0 1px 16px #080300,
      0 1px 24px #000;
    z-index: 20;
  }

  .title {
    display: inline-block;
    margin-top: 0.5rem;
    font-size: clamp(1.2rem, 3.2727vw + 0.5455rem, 3.5rem);
    text-wrap: nowrap;
    font-weight: bold;
    color: #bf6515;
    opacity: 0.85;
    text-shadow:
      0 0 2px #000,
      0 2px 4px rgba(0, 0, 0, 0.8),
      0 0 8px rgba(212, 175, 55, 0.6),
      2px 2px 8px rgba(101, 82, 40, 0.5),
      -1px -1px 2px rgba(0, 0, 0, 0.4);
    font-family: "Cinzel", serif;
    filter: contrast(1.15) brightness(1.1) saturate(1.2) sepia(0.5);
  }

  .runes {
    display: block;
    position: absolute;
    z-index: 10;
    font-family: "Runes", "Cinzel", "Palatino Linotype", serif;
    letter-spacing: 1rem;
    font-weight: bold;
    color: #573c2a;
    text-shadow: 0px 0px 2px #3d3020;
    filter:
      drop-shadow(0 0 8px #00000088) drop-shadow(0 0 16px #0000004d)
        drop-shadow(0 0 24px #8b5a0044),
      drop-shadow(0 0 32px #573c2a);
    opacity: 0.5;
  }

  .runes:nth-child(3) {
    top: 4.5rem;
    left: 0;
    font-size: clamp(3rem, 12.7273vw + 0.4545rem, 11rem);
  }

  .runes:nth-child(4) {
    top: 50%;
    left: 1rem;
    transform: translateY(-50%);
    font-size: clamp(2rem, 10.9091vw + -0.1818rem, 8rem);
  }

  .runes:nth-child(5) {
    bottom: 4.5rem;
    left: 0;
    font-size: clamp(3rem, 12.7273vw + 0.4545rem, 11rem);
  }

  #portal-section {
    position: relative;
    width: 100%;
    height: 110vh;
    overflow: hidden;
    cursor: default;
    background-color: #000000;
  }

  #portal-canvas {
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background-color: #000000;
  }

  #portal-hint {
    position: absolute;
    z-index: 10;
    bottom: 5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    color: rgba(255, 200, 100, 0.75);
    font-family: "Cinzel", "Palatino Linotype", serif;
    font-size: clamp(0.75rem, 1.5vw, 1rem);
    letter-spacing: 0.15em;
    text-shadow: 0 0 12px rgba(255, 120, 0, 0.5);
    pointer-events: none;
    transition: opacity 0.6s ease;
    background-color: #000000aa;
    animation: textGlow 3s ease-in-out infinite alternate;
  }

  #portal-hint.hidden {
    opacity: 0;
  }

  .hint-rune {
    font-size: 1.2em;
    animation: runeFlicker 2.5s ease-in-out infinite alternate;
  }

  .hint-rune:last-child {
    animation-delay: 1.25s;
  }

  @keyframes textGlow {
    0% {
      box-shadow: 0 0 6px rgba(136, 54, 0, 0.2);
    }
    50% {
      box-shadow: 0 0 18px rgba(139, 88, 0, 0.5);
    }
    100% {
      box-shadow: 0 0 6px rgba(116, 47, 1, 0.2);
    }
  }

  @keyframes runeFlicker {
    0% {
      opacity: 0.4;
      text-shadow: 0 0 6px rgba(255, 100, 0, 0.3);
    }
    100% {
      opacity: 1;
      text-shadow: 0 0 18px rgba(255, 160, 0, 0.9);
    }
  }

  #portal-section.portal-zoom {
    animation: portalZoom 2s ease-in forwards;
    transform-origin: 75% 55%;
  }

  @keyframes portalZoom {
    0% {
      transform: scale(1);
      opacity: 1;
    }
    100% {
      transform: scale(15);
    }
  }
</style>

<script>
  import * as THREE from "three";
  import { navigate } from "astro:transitions/client";

  // ─── Shaders ─────────────────────────────────────────────────────────────────

  const vertexShader = /* glsl */ `
    varying vec2 vUv;
    void main() {
      vUv = uv;
      gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
    }
  `;

  const fragmentShader = /* glsl */ `
    uniform sampler2D uTexBase;
    uniform sampler2D uTexActive;
    uniform sampler2D uMask;
    uniform float     uTime;
    uniform float     uHover;

    varying vec2 vUv;

    float hash(vec2 p) {
      return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
    }

    float noise(vec2 p) {
      vec2 i = floor(p);
      vec2 f = fract(p);
      f = f * f * (3.0 - 2.0 * f);
      return mix(
        mix(hash(i),                  hash(i + vec2(1.0, 0.0)), f.x),
        mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), f.x),
        f.y
      );
    }

    float fbm(vec2 p) {
      float value = 0.0;
      float amp   = 0.5;
      for (int i = 0; i < 5; i++) {
        value += amp * noise(p);
        p     *= 2.1;
        amp   *= 0.5;
      }
      return value;
    }

    void main() {
      float mask      = texture2D(uMask,      vUv).r;
      vec4  base      = texture2D(uTexBase,   vUv);
      vec4  texActive = texture2D(uTexActive, vUv);

      // Crossfade con noise animado — la transición no es un corte seco
      float noiseVal  = fbm(vUv * 4.0 + uTime * 0.3);
      float threshold = uHover + noiseVal * 0.15 - 0.075;
      float blend     = smoothstep(0.0, 1.0, threshold) * mask;

      vec4 color = mix(base, texActive, blend);

      gl_FragColor = color;
    }
  `;

  // ─── Fire ring shaders ───────────────────────────────────────────────────────

  const fireVertexShader = /* glsl */ `
    uniform float uTime;
    attribute float aTimeOffset;
    varying float vT;

    void main() {
      float t = fract(uTime * 0.6 + aTimeOffset);

      vec2 center = vec2(0.5, -0.1);
      vec2 dir    = normalize(position.xy - center);
      float a     = atan(dir.y, dir.x);

      float shrink = 1.0 - t * 0.6;
      float turbX  = sin(a * 7.0 + uTime * 3.5) * 0.010;
      float turbY  = cos(a * 5.0 + uTime * 2.8) * 0.008;

      vec2 pos;
      pos.x = center.x + dir.x * 0.12 * shrink + turbX;
      pos.y = center.y + dir.y * 0.18 * shrink + t * 0.5 + turbY;

      vT = t;

      vec4 mvPos = modelViewMatrix * vec4(pos, 0.0, 1.0);
      gl_PointSize = mix(8.0, 1.0, t * t);
      gl_Position  = projectionMatrix * mvPos;
    }
  `;

  // ─── Variables globales ───────────────────────────────────────────────────────

  let animationId: number | null = null;
  let renderer: THREE.WebGLRenderer | null = null;
  let resizeObserver: ResizeObserver | null = null;

  // ─── Inicialización ───────────────────────────────────────────────────────────

  async function initPortal() {
    if (animationId) cancelAnimationFrame(animationId);
    if (resizeObserver) resizeObserver.disconnect();
    if (renderer) renderer.dispose();

    const canvas = document.getElementById(
      "portal-canvas",
    ) as HTMLCanvasElement;
    const section = document.getElementById("portal-section") as HTMLElement;
    const hint = document.getElementById("portal-hint") as HTMLElement;

    if (!canvas || !section || !hint) return;

    section.classList.remove("portal-zoom");

    renderer = new THREE.WebGLRenderer({
      canvas,
      antialias: true,
      alpha: false,
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const scene = new THREE.Scene();
    const camera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
    const geometry = new THREE.PlaneGeometry(2, 2);

    // ─── Carga de texturas ────────────────────────────────────────────────────

    const loader = new THREE.TextureLoader();

    const [texBase, texActive, texMask] = await Promise.all([
      loader.loadAsync("/images/portal/portal.png"),
      loader.loadAsync("/images/portal/active_portal.png"),
      loader.loadAsync("/images/portal/portal_mask.png"),
    ]);

    // ─── Uniforms y material ──────────────────────────────────────────────────

    const uniforms = {
      uTexBase: { value: texBase },
      uTexActive: { value: texActive },
      uMask: { value: texMask },
      uTime: { value: 0.0 },
      uHover: { value: 0.0 },
    };

    const material = new THREE.ShaderMaterial({
      uniforms,
      vertexShader,
      fragmentShader,
    });
    const mesh = new THREE.Mesh(geometry, material);
    scene.add(mesh);

    // ─── Mask sampling ────────────────────────────────────────────────────────

    const maskCanvas = document.createElement("canvas");
    const maskCtx = maskCanvas.getContext("2d", { willReadFrequently: true })!;
    const maskImage = texMask.image as HTMLImageElement;
    maskCanvas.width = maskImage.naturalWidth || 256;
    maskCanvas.height = maskImage.naturalHeight || 144;
    maskCtx.drawImage(maskImage, 0, 0, maskCanvas.width, maskCanvas.height);

    function sampleMask(uvX: number, uvY: number): boolean {
      const clampedX = Math.max(0, Math.min(0.999, uvX));
      const clampedY = Math.max(0, Math.min(0.999, uvY));
      const px = Math.floor(clampedX * maskCanvas.width);
      const py = Math.floor(clampedY * maskCanvas.height);
      const data = maskCtx.getImageData(px, py, 1, 1).data;
      return data[0] > 128;
    }

    // ─── Resize ───────────────────────────────────────────────────────────────

    function resize() {
      const w = section.clientWidth;
      const h = section.clientHeight;
      renderer!.setSize(w, h, false);
    }
    resize();
    resizeObserver = new ResizeObserver(resize);
    resizeObserver.observe(section);

    // ─── Mouse tracking ───────────────────────────────────────────────────────

    let hoverTarget = 0.0;
    let isOverPortal = false;

    section.addEventListener("mousemove", (e) => {
      const rect = canvas.getBoundingClientRect();
      const uvX = (e.clientX - rect.left) / rect.width;
      const uvY = (e.clientY - rect.top) / rect.height;

      if (uvX >= 0 && uvX <= 1 && uvY >= 0 && uvY <= 1) {
        isOverPortal = sampleMask(uvX, uvY);
        hoverTarget = isOverPortal ? 1.0 : 0.0;

        canvas.style.cursor = isOverPortal
          ? 'url("/cursor/pointer_fixed.cur") 16 2, pointer'
          : 'url("/cursor/cursor_fixed.cur") 0 0, auto';

        if (isOverPortal) {
          hint.classList.add("hidden");
        } else {
          hint.classList.remove("hidden");
        }
      }
    });

    section.addEventListener("mouseleave", () => {
      hoverTarget = 0.0;
      isOverPortal = false;
      section.style.cursor = "default";
      canvas.style.cursor = "default";
      hint.classList.remove("hidden");
    });

    // ─── Click → zoom + navegación ────────────────────────────────────────────

    canvas.addEventListener("click", (e) => {
      const rect = canvas.getBoundingClientRect();
      const clickX = (e.clientX - rect.left) / rect.width;
      const clickY = (e.clientY - rect.top) / rect.height;

      if (sampleMask(clickX, clickY)) {
        section.classList.add("portal-zoom");
        setTimeout(() => navigate("/serie"), 1500);
      }
    });

    // ─── Loop de animación ────────────────────────────────────────────────────

    const clock = new THREE.Timer();

    function animate() {
      animationId = requestAnimationFrame(animate);

      uniforms.uTime.value = clock.getElapsed();
      uniforms.uHover.value = THREE.MathUtils.lerp(
        uniforms.uHover.value,
        hoverTarget,
        0.04,
      );

      renderer!.render(scene, camera);
    }
    animate();
  }

  initPortal();
  document.addEventListener("astro:page-load", initPortal);
</script>
