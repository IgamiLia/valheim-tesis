---
interface Props {
  targetHref?: string;
}
const { targetHref = "#serie" } = Astro.props;
---

<section class="portal-section" id="portal-section">
  <div class="portal-bg"></div>

  <div class="portal-text">
    <p class="portal-label">La Serie</p>
    <h2 class="portal-title">Valheim:<br />Larga vida<br />a La Reina</h2>
    <p class="portal-hint">Cruzá el umbral</p>
    <div class="portal-runes" aria-hidden="true">
      ᚠᚢᚦᚨᚱᚲ<br />ᚷᚹᚺᚾᛁᛃ<br />ᛇᛈᛉᛊᛏᛒ<br />ᛖᛗᛚᛜᛞᛟ
    </div>
  </div>

  <canvas id="portal-canvas"></canvas>

  <div class="portal-cta" id="portal-cta">
    <span>Entrar</span>
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
    >
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </div>
</section>

<script>
  import * as THREE from "three";

  const canvas = document.getElementById("portal-canvas") as HTMLCanvasElement;
  const section = document.getElementById("portal-section") as HTMLElement;
  const ctaEl = document.getElementById("portal-cta") as HTMLElement;

  const W = window.innerWidth;
  const H = window.innerHeight;

  const renderer = new THREE.WebGLRenderer({
    canvas,
    antialias: true,
    alpha: true,
  });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(W, H);
  renderer.setClearColor(0x000000, 0);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(55, W / H, 0.1, 100);
  camera.position.set(0, 0.3, 6);
  camera.lookAt(0, 0, 0);

  // ── Materiales ──────────────────────────────────────────────────────

  const stoneMat = new THREE.MeshStandardMaterial({
    color: 0x1c1c18,
    roughness: 0.9,
    metalness: 0.15,
  });

  const darkMat = new THREE.MeshStandardMaterial({
    color: 0x0a0a08,
    roughness: 1.0,
    metalness: 0.0,
  });

  const glowMat = new THREE.MeshStandardMaterial({
    color: 0x00dd44,
    emissive: new THREE.Color(0x00cc33),
    emissiveIntensity: 2.0,
    roughness: 0.2,
    metalness: 0.8,
  });

  // ── Grupo principal ─────────────────────────────────────────────────

  const doorGroup = new THREE.Group();
  scene.add(doorGroup);

  function box(
    w: number,
    h: number,
    d: number,
    mat: THREE.Material,
    x: number,
    y: number,
    z: number,
    parent: THREE.Object3D,
  ): THREE.Mesh {
    const m = new THREE.Mesh(new THREE.BoxGeometry(w, h, d), mat);
    m.position.set(x, y, z);
    parent.add(m);
    return m;
  }

  // Jambas
  box(0.5, 5.5, 0.5, stoneMat, -1.85, 0.5, 0, doorGroup);
  box(0.5, 5.5, 0.5, stoneMat, 1.85, 0.5, 0, doorGroup);

  // Dintel
  box(4.2, 0.55, 0.5, stoneMat, 0, 3.0, 0, doorGroup);
  box(3.8, 0.3, 0.45, stoneMat, 0, 3.38, 0, doorGroup);
  box(3.2, 0.25, 0.4, stoneMat, 0, 3.62, 0, doorGroup);

  // Base y escalones
  box(4.0, 0.18, 0.6, stoneMat, 0, -2.1, 0, doorGroup);
  for (let i = 0; i < 3; i++) {
    box(
      4.5 + i * 0.4,
      0.16,
      0.4 + i * 0.3,
      stoneMat,
      0,
      -2.25 - i * 0.16,
      -i * 0.2,
      doorGroup,
    );
  }

  // Anillos decorativos sobre el dintel
  const ring1 = new THREE.Mesh(
    new THREE.TorusGeometry(0.55, 0.07, 10, 40),
    stoneMat,
  );
  ring1.position.set(0, 2.2, 0.26);
  doorGroup.add(ring1);

  const ring2 = new THREE.Mesh(
    new THREE.TorusGeometry(0.38, 0.04, 10, 40),
    glowMat,
  );
  ring2.position.set(0, 2.2, 0.28);
  doorGroup.add(ring2);

  // Gema central
  const gem = new THREE.Mesh(new THREE.OctahedronGeometry(0.2, 0), glowMat);
  gem.position.set(0, 2.2, 0.38);
  doorGroup.add(gem);

  // Relieves horizontales en jambas
  for (let i = 0; i < 5; i++) {
    const y = -1.5 + i * 0.9;
    box(0.52, 0.06, 0.56, darkMat, -1.85, y, 0, doorGroup);
    box(0.52, 0.06, 0.56, darkMat, 1.85, y, 0, doorGroup);
  }

  // Paneles de la puerta
  const panelGeo = new THREE.BoxGeometry(1.3, 4.8, 0.14);
  const leftPanel = new THREE.Mesh(panelGeo, darkMat);
  const rightPanel = new THREE.Mesh(panelGeo, darkMat);
  leftPanel.position.set(-0.65, 0.3, 0.18);
  rightPanel.position.set(0.65, 0.3, 0.18);
  doorGroup.add(leftPanel);
  doorGroup.add(rightPanel);

  // Relieves verticales en los paneles
  for (let i = 0; i < 2; i++) {
    const xOff = i === 0 ? -0.22 : 0.22;
    box(0.07, 4.2, 0.05, stoneMat, -0.65 + xOff, 0.3, 0.26, doorGroup);
    box(0.07, 4.2, 0.05, stoneMat, 0.65 + xOff, 0.3, 0.26, doorGroup);
  }

  // ── Shader del portal ───────────────────────────────────────────────

  const portalMat = new THREE.ShaderMaterial({
    uniforms: {
      uTime: { value: 0.0 },
      uIntensity: { value: 0.0 },
    },
    vertexShader: `
            varying vec2 vUv;
            void main() {
                vUv = uv;
                gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
            }
        `,
    fragmentShader: `
            uniform float uTime;
            uniform float uIntensity;
            varying vec2 vUv;

            float hash(vec2 p) {
                return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
            }

            float noise(vec2 p) {
                vec2 i = floor(p);
                vec2 f = fract(p);
                f = f * f * (3.0 - 2.0 * f);
                return mix(
                    mix(hash(i), hash(i + vec2(1.0, 0.0)), f.x),
                    mix(hash(i + vec2(0.0, 1.0)), hash(i + vec2(1.0, 1.0)), f.x),
                    f.y
                );
            }

            float fbm(vec2 p) {
                float v = 0.0;
                float a = 0.5;
                for (int i = 0; i < 5; i++) {
                    v += a * noise(p);
                    p  = p * 2.0 + vec2(1.7, 9.2);
                    a *= 0.5;
                }
                return v;
            }

            void main() {
                vec2 uv  = vUv - 0.5;
                float fog = fbm(uv * 3.0 + vec2(uTime * 0.12, uTime * 0.07));
                fog      += fbm(uv * 5.5 - vec2(uTime * 0.09, uTime * 0.11)) * 0.5;

                float dist    = length(uv);
                float vignette = 1.0 - smoothstep(0.05, 0.5, dist);

                vec3 col  = vec3(0.0, fog * 0.95, fog * 0.35) * vignette;
                col      += vec3(0.0, 0.25, 0.08) * (1.0 - dist * 1.5) * 0.5;

                float alpha = (fog * 0.75 + 0.1) * vignette * uIntensity;
                gl_FragColor = vec4(col, clamp(alpha, 0.0, 1.0));
            }
        `,
    transparent: true,
    side: THREE.DoubleSide,
    depthWrite: false,
  });

  const portalPlane = new THREE.Mesh(
    new THREE.PlaneGeometry(1.32, 4.8),
    portalMat,
  );
  portalPlane.position.set(0, 0.3, 0.15);
  doorGroup.add(portalPlane);

  // ── Partículas ──────────────────────────────────────────────────────

  const COUNT = 140;
  const positions = new Float32Array(COUNT * 3);
  for (let i = 0; i < COUNT; i++) {
    positions[i * 3] = (Math.random() - 0.5) * 1.8;
    positions[i * 3 + 1] = (Math.random() - 0.5) * 5.0;
    positions[i * 3 + 2] = (Math.random() - 0.5) * 0.3;
  }

  const particleGeo = new THREE.BufferGeometry();
  particleGeo.setAttribute("position", new THREE.BufferAttribute(positions, 3));

  const particleMat = new THREE.PointsMaterial({
    color: 0x44ff88,
    size: 0.035,
    transparent: true,
    opacity: 0,
    depthWrite: false,
  });

  const particles = new THREE.Points(particleGeo, particleMat);
  particles.position.set(0, 0, 0.2);
  doorGroup.add(particles);

  // ── Luces ───────────────────────────────────────────────────────────

  scene.add(new THREE.AmbientLight(0x0a0a08, 2));

  const greenLight = new THREE.PointLight(0x00ff55, 0, 8);
  greenLight.position.set(0, 0.5, 1.5);
  scene.add(greenLight);

  const topLight = new THREE.DirectionalLight(0x223322, 0.6);
  topLight.position.set(0, 5, 3);
  scene.add(topLight);

  const rimLight = new THREE.DirectionalLight(0x001a08, 0.4);
  rimLight.position.set(-3, 0, 2);
  scene.add(rimLight);

  // ── Estado ──────────────────────────────────────────────────────────

  let isHovered = false;
  let openProgress = 0;
  let targetHref =
    (document.getElementById("portal-section") as any).__targetHref || "#serie";

  const clock = new THREE.Clock();

  const LEFT_CLOSED = -0.65;
  const RIGHT_CLOSED = 0.65;
  const OPEN_OFFSET = 0.85;

  function lerp(a: number, b: number, t: number) {
    return a + (b - a) * t;
  }

  // ── Eventos ─────────────────────────────────────────────────────────

  section.addEventListener("mouseenter", () => {
    isHovered = true;
  });
  section.addEventListener("mouseleave", () => {
    isHovered = false;
  });

  section.addEventListener("click", () => {
    const href = section.dataset.href ?? "/serie/index.html";
    const target = document.querySelector(href);
    if (target) {
      target.scrollIntoView({ behavior: "smooth" });
    } else {
      window.location.href = href;
    }
  });

  let mouseX = 0;
  let mouseY = 0;
  section.addEventListener("mousemove", (e: MouseEvent) => {
    mouseX = (e.clientX / window.innerWidth - 0.5) * 0.18;
    mouseY = (e.clientY / window.innerHeight - 0.5) * 0.1;
  });

  window.addEventListener("resize", () => {
    const w = window.innerWidth;
    const h = window.innerHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  });

  // ── Loop ────────────────────────────────────────────────────────────

  function animate() {
    requestAnimationFrame(animate);

    const elapsed = clock.getElapsedTime();

    // Abrir / cerrar paneles
    openProgress = lerp(openProgress, isHovered ? 1 : 0, 0.035);

    leftPanel.position.x = lerp(
      LEFT_CLOSED,
      LEFT_CLOSED - OPEN_OFFSET,
      openProgress,
    );
    rightPanel.position.x = lerp(
      RIGHT_CLOSED,
      RIGHT_CLOSED + OPEN_OFFSET,
      openProgress,
    );

    // Niebla
    portalMat.uniforms.uTime.value = elapsed;
    portalMat.uniforms.uIntensity.value = lerp(
      portalMat.uniforms.uIntensity.value,
      0.25 + openProgress * 0.75,
      0.04,
    );

    // Luz verde
    greenLight.intensity = lerp(greenLight.intensity, openProgress * 4.0, 0.04);

    // Partículas
    particleMat.opacity = lerp(particleMat.opacity, openProgress * 0.85, 0.04);
    const pos = particleGeo.attributes.position.array as Float32Array;
    for (let i = 0; i < COUNT; i++) {
      pos[i * 3 + 1] += 0.0025 * openProgress;
      if (pos[i * 3 + 1] > 2.5) pos[i * 3 + 1] = -2.5;
    }
    particleGeo.attributes.position.needsUpdate = true;

    // Gema
    gem.rotation.y = elapsed * 0.9;
    gem.rotation.x = elapsed * 0.55;
    const pulse = 1 + Math.sin(elapsed * 2.2) * 0.06;
    gem.scale.setScalar(pulse);
    (ring2.material as THREE.MeshStandardMaterial).emissiveIntensity =
      0.8 + openProgress * 1.8 + Math.sin(elapsed * 3) * 0.2;

    // Parallax mouse
    doorGroup.rotation.y = lerp(doorGroup.rotation.y, mouseX, 0.06);
    doorGroup.rotation.x = lerp(doorGroup.rotation.x, -mouseY, 0.06);

    // CTA
    const ctaOpacity =
      openProgress > 0.3 ? Math.min((openProgress - 0.3) / 0.4, 1) : 0;
    ctaEl.style.opacity = String(ctaOpacity);

    renderer.render(scene, camera);
  }

  animate();
</script>

<style>
  .portal-section {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .portal-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 70% 80% at 62% 50%,
        #080f08 0%,
        #040704 45%,
        #020302 100%
      ),
      radial-gradient(ellipse 50% 60% at 15% 75%, #050d05 0%, transparent 55%);
    z-index: 0;
  }

  #portal-canvas {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    z-index: 1;
  }

  .portal-text {
    position: relative;
    z-index: 2;
    padding: 0 0 0 6vw;
    max-width: 320px;
    pointer-events: none;
    user-select: none;
  }

  .portal-label {
    font-size: 0.62rem;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: rgba(60, 200, 100, 0.65);
    margin: 0 0 0.9rem;
    font-family: "Georgia", serif;
  }

  .portal-title {
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    font-weight: 400;
    color: #ddd9c6;
    margin: 0 0 1.2rem;
    line-height: 1.08;
    font-family: "Palatino Linotype", "Book Antiqua", Palatino, serif;
    letter-spacing: 0.015em;
    text-shadow: 0 0 50px rgba(0, 255, 70, 0.12);
  }

  .portal-hint {
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(160, 190, 160, 0.35);
    margin: 0 0 2rem;
    font-family: "Georgia", serif;
  }

  .portal-runes {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: rgba(60, 180, 90, 0.18);
    font-family: monospace;
    line-height: 2.1;
  }

  .portal-cta {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.68rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(70, 220, 110, 0.75);
    opacity: 0;
    pointer-events: none;
    font-family: "Georgia", serif;
  }

  .portal-cta svg {
    width: 14px;
    height: 14px;
    animation: arrowPulse 1.6s ease-in-out infinite;
  }

  @keyframes arrowPulse {
    0%,
    100% {
      transform: translateX(0);
    }
    50% {
      transform: translateX(5px);
    }
  }

  @media (max-width: 768px) {
    .portal-text {
      padding: 0 0 0 1.5rem;
      max-width: 190px;
    }
    .portal-title {
      font-size: 1.5rem;
    }
    .portal-runes {
      display: none;
    }
  }
</style>
