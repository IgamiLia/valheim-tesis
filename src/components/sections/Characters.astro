---
import Layout from "@layouts/Layout.astro";
import CharacterCard from "@components/ui/CharacterCard.astro";
import "@styles/global.css";
const characters = [
  {
    name: "Einar",
    img: "/images/EinarVsModer.webp",
    portrait: "/images/einar_character.png",
  },
  {
    name: "Runa",
    img: "/images/EinarVsModer.webp",
    portrait: "/images/einar_character.png",
  },
  {
    name: "Hel",
    img: "/images/EinarVsModer.webp",
    portrait: "/images/einar_character.png",
  },
  {
    name: "Sombra",
    img: "/images/EinarVsModer.webp",
    portrait: "/images/einar_character.png",
  },
  {
    name: "Moder",
    img: "/images/EinarVsModer.webp",
    portrait: "/images/einar_character.png",
  },
  {
    name: "Fader",
    img: "/images/EinarVsModer.webp",
    portrait: "/images/einar_character.png",
  },
];
---

<Layout title="Valheim: Larga vida a La Reina | Personajes">
  <!-- <div class="background"></div> -->

  <img
    id="characters-logo"
    src="/images/logos/personajes_logo.png"
    alt="Logo de Personajes"
  />

  <main>
    {
      characters.map((char, i) => (
        <CharacterCard
          name={char.name}
          img={char.img}
          portrait={char.portrait}
          index={i}
        />
      ))
    }
  </main>
  <div class="presentation hidden">
    <div class="presentation__text hidden"></div>
    <div class="presentation__card"></div>
    <div class="presentation__character"></div>
  </div>

  <section class="modal hidden">
    <div class="overlay hidden"></div>
  </section>

  <script src="@scripts/characters.js"></script>
</Layout>
