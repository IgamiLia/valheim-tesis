---

---

<audio id="bg-audio" src="/ost/characters.mp3" loop preload="auto"></audio>

<button class="music-btn paused" aria-label="Toggle music" aria-pressed="false">
  <svg
    class="icon-pause"
    viewBox="0 0 24 24"
    fill="currentColor"
    width="24"
    height="24"
  >
    <rect x="6" y="4" width="4" height="16" rx="1"></rect>
    <rect x="14" y="4" width="4" height="16" rx="1"></rect>
  </svg>
  <svg
    class="icon-play"
    viewBox="0 0 24 24"
    fill="currentColor"
    width="24"
    height="24"
  >
    <path d="M8 5v14l11-7z"></path>
  </svg>
</button>

<script>
  const AUDIO_KEY = "bg-audio-playing";

  function initMusicPlayer() {
    const audio = document.getElementById("bg-audio") as HTMLAudioElement;
    const btn = document.querySelector(".music-btn") as HTMLElement;
    if (!audio || !btn) return;

    function syncBtn() {
      const playing = !audio.paused;
      btn.classList.toggle("paused", !playing);
      btn.setAttribute("aria-pressed", String(playing));
    }

    if (!btn.dataset.initialized) {
      btn.dataset.initialized = "1";

      btn.addEventListener("click", async () => {
        if (audio.paused) {
          await audio.play().catch(() => {});
          localStorage.setItem(AUDIO_KEY, "true");
        } else {
          audio.pause();
          localStorage.setItem(AUDIO_KEY, "false");
        }
        syncBtn();
      });

      audio.addEventListener("play", () => {
        localStorage.setItem(AUDIO_KEY, "true");
        syncBtn();
      });
      audio.addEventListener("pause", () => {
        localStorage.setItem(AUDIO_KEY, "false");
        syncBtn();
      });
    }

    if (localStorage.getItem(AUDIO_KEY) === "true" && audio.paused) {
      audio.play().catch(() => {});
    }
    syncBtn();
  }

  document.addEventListener("astro:page-load", initMusicPlayer);
</script>

<style>
  .music-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    padding: 0;
    background: linear-gradient(
      135deg,
      rgba(20, 14, 4, 0.95) 0%,
      rgba(40, 30, 15, 0.9) 100%
    );
    border: 2px solid var(--color-gold-dark);
    border-radius: 50%;
    color: var(--color-gold);
    box-shadow:
      0 0 0 1px rgba(10, 9, 6, 0.8),
      0 0 15px 3px rgba(130, 103, 40, 0.3),
      inset 0 1px 0 rgba(220, 195, 120, 0.1);
    transition: all 0.3s ease;
  }

  .music-btn:hover {
    border-color: var(--gold);
    box-shadow:
      0 0 0 1px rgba(10, 9, 6, 0.8),
      0 0 25px 5px rgba(180, 151, 76, 0.5),
      inset 0 1px 0 rgba(220, 195, 120, 0.2);
    transform: translateY(-2px);
  }

  .music-btn svg {
    width: 22px;
    height: 22px;
    transition: all 0.3s ease;
  }

  .music-btn .icon-pause {
    display: none;
  }

  .music-btn .icon-play {
    display: block;
  }

  .music-btn:not(.paused) .icon-pause {
    display: block;
  }

  .music-btn:not(.paused) .icon-play {
    display: none;
  }

  @media (max-width: 600px) {
    .music-btn {
      bottom: 1rem;
      right: 1rem;
      width: 44px;
      height: 44px;
    }

    .music-btn svg {
      width: 18px;
      height: 18px;
    }
  }
</style>
