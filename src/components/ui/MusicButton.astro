---
interface Props {
  audioSrc: string;
}
const { audioSrc } = Astro.props;
---

<audio id="bg-audio" src={audioSrc} loop preload="auto"></audio>

<button
  id="music-btn"
  class="music-btn paused"
  aria-label="Toggle music"
  aria-pressed="false"
>
  <svg
    width="24"
    height="24"
    fill="currentColor"
    class="icon-pause"
    viewBox="0 0 24 24"
  >
    <rect width="4" height="16" x="6" y="4" rx="1"></rect>
    <rect width="4" height="16" x="14" y="4" rx="1"></rect>
  </svg>
  <svg
    width="24"
    height="24"
    fill="currentColor"
    class="icon-play"
    viewBox="0 0 24 24"
  >
    <path d="M8 5v14l11-7z"></path>
  </svg>
</button>

<script>
  const audio = document.getElementById("bg-audio") as HTMLAudioElement;
  const btn = document.getElementById("music-btn") as HTMLButtonElement;

  function setPlayingState(playing: boolean): void {
    btn.classList.toggle("paused", !playing);
    btn.setAttribute("aria-pressed", String(playing));
  }

  function fade(from: number, to: number, duration = 300): Promise<void> {
    return new Promise((resolve) => {
      const startTime = performance.now();
      const tick = (now: number) => {
        const t = Math.min((now - startTime) / duration, 1);
        audio.volume = Math.max(0, Math.min(1, from + (to - from) * t));
        t < 1 ? requestAnimationFrame(tick) : resolve();
      };
      requestAnimationFrame(tick);
    });
  }

  // Autoplay con fade in
  audio.volume = 0;
  audio
    .play()
    .then(() => fade(0, 1).then(() => setPlayingState(true)))
    .catch(() => {
      audio.volume = 1;
      setPlayingState(false);
    });

  // Toggle play / pause
  btn.addEventListener("click", async () => {
    if (audio.paused) {
      audio.volume = 0;
      await audio.play();
      await fade(0, 1);
      setPlayingState(true);
    } else {
      await fade(audio.volume, 0);
      audio.pause();
      setPlayingState(false);
    }
  });
</script>

<style>
  .music-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 50px;
    height: 50px;
    padding: 0;
    background: linear-gradient(
      135deg,
      rgba(20, 14, 4, 0.95) 0%,
      rgba(40, 30, 15, 0.9) 100%
    );
    border: 2px solid var(--color-gold-dark);
    border-radius: 50%;
    color: var(--color-gold);
    box-shadow:
      0 0 0 1px rgba(10, 9, 6, 0.8),
      0 0 15px 3px rgba(130, 103, 40, 0.3),
      inset 0 1px 0 rgba(220, 195, 120, 0.1);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .music-btn:hover {
    border-color: var(--gold);
    box-shadow:
      0 0 0 1px rgba(10, 9, 6, 0.8),
      0 0 25px 5px rgba(180, 151, 76, 0.5),
      inset 0 1px 0 rgba(220, 195, 120, 0.2);
    transform: translateY(-2px);
  }

  .music-btn svg {
    width: 22px;
    height: 22px;
    transition: all 0.3s ease;
  }

  .music-btn .icon-pause {
    display: none;
  }
  .music-btn .icon-play {
    display: block;
  }

  .music-btn:not(.paused) .icon-pause {
    display: block;
  }
  .music-btn:not(.paused) .icon-play {
    display: none;
  }

  @media (max-width: 600px) {
    .music-btn {
      bottom: 1rem;
      right: 1rem;
      width: 44px;
      height: 44px;
    }

    .music-btn svg {
      width: 18px;
      height: 18px;
    }
  }
</style>
